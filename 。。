plr = game:GetService("Players")
twn = game:GetService("TweenService")
lgt = game:GetService("Lighting")
run = game:GetService("RunService")
p = plr.LocalPlayer
pg = p:WaitForChild("PlayerGui")
cfg = {
    Image1 = "rbxassetid://122762067523704",
    Image2 = "rbxassetid://102338062356229",
    ImageSize = UDim2.new(0, 300, 0, 300),
    Position = UDim2.new(0.5, 0, 0.3, 0),
    Text1 = "Welcome To Use Se",
    Text2 = "Fuck you",
    TextSize = 48,
    TextPosition = UDim2.new(0.5, 0, 0.6, 0),
    FadeInDuration = 0.5,
    ShakeDuration = 0.8,
    ShakeIntensity = 10,
    CrossfadeDuration = 0.3,
    ColorChangeDuration = 0.3,
    DisplayDuration = 2,
    FadeOutDuration = 0.8,
    BlurSize = 10
}
Font = Font.fromId(12187369639, Enum.FontWeight.Bold, Enum.FontStyle.Normal)
gui = Instance.new("ScreenGui")
gui.Name = "11"
gui.Parent = pg
gui.ResetOnSpawn = false
img1 = Instance.new("ImageLabel")
img1.Size = cfg.ImageSize
img1.AnchorPoint = Vector2.new(0.5, 0.5)
img1.Position = cfg.Position
img1.BackgroundTransparency = 1
img1.BorderSizePixel = 0
img1.ScaleType = Enum.ScaleType.Fit
img1.Image = cfg.Image1
img1.ImageTransparency = 1
img1.Parent = gui
img2 = Instance.new("ImageLabel")
img2.Size = cfg.ImageSize
img2.AnchorPoint = Vector2.new(0.5, 0.5)
img2.Position = cfg.Position
img2.BackgroundTransparency = 1
img2.BorderSizePixel = 0
img2.ScaleType = Enum.ScaleType.Fit
img2.Image = cfg.Image2
img2.ImageTransparency = 1
img2.Parent = gui

txt1 = Instance.new("TextLabel")
txt1.Size = UDim2.new(0, 400, 0, 60)
txt1.AnchorPoint = Vector2.new(0.5, 0.5)
txt1.Position = cfg.TextPosition
txt1.BackgroundTransparency = 1
txt1.BorderSizePixel = 0
txt1.Text = cfg.Text1
txt1.FontFace = Font
txt1.TextSize = cfg.TextSize
txt1.TextColor3 = Color3.fromRGB(255, 255, 255)
txt1.TextTransparency = 1
txt1.TextStrokeTransparency = 0.5
txt1.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
txt1.Parent = gui
txt2 = Instance.new("TextLabel")
txt2.Size = UDim2.new(0, 400, 0, 60)
txt2.AnchorPoint = Vector2.new(0.5, 0.5)
txt2.Position = cfg.TextPosition
txt2.BackgroundTransparency = 1
txt2.BorderSizePixel = 0
txt2.Text = cfg.Text2
txt2.FontFace = Font
txt2.TextSize = cfg.TextSize
txt2.TextColor3 = Color3.fromRGB(255, 255, 255)
txt2.TextTransparency = 1
txt2.TextStrokeTransparency = 0.5
txt2.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
txt2.Parent = gui
org = img1.Position
blu = Instance.new("BlurEffect")
dof = Instance.new("DepthOfFieldEffect")
dof.FarIntensity = 0
dof.InFocusRadius = 0.1
dof.NearIntensity = 1
orgEff = {}
trg = {lgt, workspace.CurrentCamera}
for _, par in ipairs(trg) do
    if par then
        for _, eff in ipairs(par:GetChildren()) do
            if eff:IsA("BlurEffect") or eff:IsA("DepthOfFieldEffect") then
                orgEff[eff] = {Enabled = eff.Enabled}
                eff.Enabled = false
            end
        end
    end
end
blu.Parent = lgt
dof.Parent = lgt
bluTwn = twn:Create(blu, 
    TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {Size = cfg.BlurSize} )
bluTwn:Play()
finImg = twn:Create(img1,
    TweenInfo.new(cfg.FadeInDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {ImageTransparency = 0} )
finImg:Play()
finTxt = twn:Create(txt1,
    TweenInfo.new(cfg.FadeInDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {TextTransparency = 0} )
finTxt:Play()
finTxt.Completed:Wait()
task.wait(1.5)
shkSta = tick()
shkCon = nil
shkCon = run.RenderStepped:Connect(function()
    ela = tick() - shkSta
    if ela >= cfg.ShakeDuration then
        img1.Position = org
        img2.Position = org
        shkCon:Disconnect()
        return
    end
    curInt = cfg.ShakeIntensity * (1 - ela / cfg.ShakeDuration)
    offX = (math.random() * 2 - 1) * curInt
    offY = (math.random() * 2 - 1) * curInt
    
    newPos = UDim2.new(
        org.X.Scale, org.X.Offset + offX,
        org.Y.Scale, org.Y.Offset + offY
    )
    
    img1.Position = newPos
    img2.Position = newPos
end)
task.wait(cfg.ShakeDuration)
img1.Position = org
img2.Position = org
crsImg1 = twn:Create(img1,
    TweenInfo.new(cfg.CrossfadeDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {ImageTransparency = 1} )
crsImg1:Play()
crsImg2 = twn:Create(img2,
    TweenInfo.new(cfg.CrossfadeDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {ImageTransparency = 0} )
crsImg2:Play()
crsTxt1 = twn:Create(txt1,
    TweenInfo.new(cfg.CrossfadeDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {TextTransparency = 1} )
crsTxt1:Play()
crsTxt2 = twn:Create(txt2,
    TweenInfo.new(cfg.CrossfadeDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {TextTransparency = 0} )
crsTxt2:Play()
clrTwn = twn:Create(txt2,
    TweenInfo.new(cfg.ColorChangeDuration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
    {TextColor3 = Color3.fromRGB(255, 0, 0)}
)
clrTwn:Play()
clrTwn.Completed:Wait()
img1:Destroy()
txt1:Destroy()
task.wait(cfg.DisplayDuration)
fotImg = twn:Create(img2,
    TweenInfo.new(cfg.FadeOutDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {ImageTransparency = 1} )
fotImg:Play()
fotTxt = twn:Create(txt2,
    TweenInfo.new(cfg.FadeOutDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    {TextTransparency = 1} )
fotTxt:Play()
fotTxt.Completed:Wait()
bluOut = twn:Create(blu,
    TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
    {Size = 0} )
bluOut:Play()
bluOut.Completed:Wait()
blu:Destroy()
dof:Destroy()
for eff, dat in pairs(orgEff) do
    if eff then eff.Enabled = dat.Enabled end
end
gui:Destroy()