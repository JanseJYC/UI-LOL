                })
                
                slider.Track = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 6),
                    ImageColor3 = self.Theme.ToggleDisabled,
                    ImageTransparency = 0.4,
                    Parent = slider.Frame,
                })
                
                local percent = (slider.Value - slider.Min) / (slider.Max - slider.Min)
                slider.Fill = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(percent, 0, 1, 0),
                    ImageColor3 = self.Theme.SliderFill,
                    ImageTransparency = 0,
                    Parent = slider.Track,
                })
                
                slider.Thumb = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new(percent, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    ImageColor3 = Color3.new(1, 1, 1),
                    ImageTransparency = 0,
                    Parent = slider.Fill,
                })
                
                local dragging = false
                
                local function update(input)
                    local pos = math.clamp((input.Position.X - slider.Track.AbsolutePosition.X) / slider.Track.AbsoluteSize.X, 0, 1)
                    local value = math.floor((pos * (slider.Max - slider.Min) + slider.Min) / slider.Step) * slider.Step
                    slider.Value = value
                    valueLabel.Text = tostring(value) .. slider.Suffix
                    slider.Fill.Size = UDim2.new(pos, 0, 1, 0)
                    slider.Thumb.Position = UDim2.new(pos, 0, 0.5, 0)
                    pcall(slider.Callback, value)
                end
                
                slider.Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        update(input)
                        Tween(slider.Thumb, 0.15, {Size = UDim2.new(0, 18, 0, 18)})
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        update(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                        Tween(slider.Thumb, 0.15, {Size = UDim2.new(0, 14, 0, 14)})
                    end
                end)
                
                return slider
            end
            
