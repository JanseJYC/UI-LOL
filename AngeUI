                })
                
                local btnPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                    Parent = btn.Frame,
                })
                
                local btnLabel = New("TextLabel", {
                    Text = btn.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 14,
                    TextColor3 = Color3.new(1, 1, 1),
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Parent = btn.Frame,
                })
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = btn.Frame,
                })
                
                hitbox.MouseEnter:Connect(function()
                    Tween(btn.Frame, 0.15, {ImageTransparency = 0.2})
                end)
                
                hitbox.MouseLeave:Connect(function()
                    Tween(btn.Frame, 0.15, {ImageTransparency = 0})
                end)
                
                hitbox.MouseButton1Click:Connect(function()
                    Tween(btn.Frame.UIScale or btn.Frame, 0.1, {Scale = 0.95})
                    task.delay(0.1, function()
                        Tween(btn.Frame.UIScale or btn.Frame, 0.1, {Scale = 1})
                    end)
                    pcall(btn.Callback)
                end)
                
                return btn
            end
            
            function section:Toggle(config)
                local toggle = {}
                toggle.Title = config.Title or "Toggle"
                toggle.Default = config.Default or false
                toggle.Callback = config.Callback or function() end
                toggle.Value = toggle.Default
                
                toggle.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 36),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    Padding = UDim.new(0, 10),
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Parent = toggle.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = toggle.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -50, 1, 0),
                    Parent = toggle.Frame,
                })
                
                toggle.SwitchFrame = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(0, 44, 0, 24),
                    ImageColor3 = toggle.Default and self.Theme.ToggleEnabled or self.Theme.ToggleDisabled,
                    ImageTransparency = 0,
                    Parent = toggle.Frame,
                })
                
                toggle.Thumb = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(0, 18, 0, 18),
                    Position = toggle.Default and UDim2.new(1, -21, 0.5, 0) or UDim2.new(0, 3, 0.5, 0),
                    AnchorPoint = Vector2.new(0, 0.5),
                    ImageColor3 = Color3.new(1, 1, 1),
                    ImageTransparency = 0,
                    Parent = toggle.SwitchFrame,
                })
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = toggle.Frame,
                })
                
                function toggle:Set(value)
                    toggle.Value = value
                    Tween(toggle.SwitchFrame, 0.2, {ImageColor3 = value and self.Theme.ToggleEnabled or self.Theme.ToggleDisabled})
                    Tween(toggle.Thumb, 0.2, {Position = value and UDim2.new(1, -21, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)})
                    pcall(toggle.Callback, value)
                end
                
                hitbox.MouseButton1Click:Connect(function()
                    toggle:Set(not toggle.Value)
                end)
                
                return toggle
            end
            
            function section:Slider(config)
                local slider = {}
                slider.Title = config.Title or "Slider"
                slider.Min = config.Min or 0
                slider.Max = config.Max or 100
                slider.Default = config.Default or slider.Min
                slider.Step = config.Step or 1
                slider.Callback = config.Callback or function() end
                slider.Value = slider.Default
                
                slider.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 50),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 6),
                    Parent = slider.Frame,
                })
                
                local header = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Parent = slider.Frame,
                })
                
                local headerLayout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    Parent = header,
                })
                
                local title = New("TextLabel", {
                    Text = slider.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -50, 1, 0),
                    Parent = header,
                })
                
                local valueLabel = New("TextLabel", {
                    Text = tostring(slider.Value),
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 14,
                    TextColor3 = self.Theme.Accent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0, 50, 1, 0),
                    Parent = header,
                })
                
                slider.Track = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 6),
                    ImageColor3 = self.Theme.ToggleDisabled,
                    ImageTransparency = 0.5,
                    Parent = slider.Frame,
                })
                
                local percent = (slider.Value - slider.Min) / (slider.Max - slider.Min)
                slider.Fill = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(percent, 0, 1, 0),
                    ImageColor3 = self.Theme.SliderFill,
                    ImageTransparency = 0,
                    Parent = slider.Track,
                })
                
                slider.Thumb = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new(percent, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    ImageColor3 = Color3.new(1, 1, 1),
                    ImageTransparency = 0,
                    Parent = slider.Fill,
                })
                
                local dragging = false
                
                local function update(input)
                    local pos = math.clamp((input.Position.X - slider.Track.AbsolutePosition.X) / slider.Track.AbsoluteSize.X, 0, 1)
                    local value = math.floor((pos * (slider.Max - slider.Min) + slider.Min) / slider.Step) * slider.Step
                    slider.Value = value
                    valueLabel.Text = tostring(value)
                    slider.Fill.Size = UDim2.new(pos, 0, 1, 0)
                    slider.Thumb.Position = UDim2.new(pos, 0, 0.5, 0)
                    pcall(slider.Callback, value)
                end
                
                slider.Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        update(input)
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        update(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                return slider
            end
            
            function section:Dropdown(config)
                local dropdown = {}
                dropdown.Title = config.Title or "Dropdown"
                dropdown.Options = config.Options or {}
                dropdown.Default = config.Default
                dropdown.Callback = config.Callback or function() end
                dropdown.Opened = false
                
                dropdown.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 36),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 6),
                    Parent = dropdown.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = dropdown.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    Parent = dropdown.Frame,
                })
                
                dropdown.Button = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 36),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.9,
                    Parent = dropdown.Frame,
                })
                
                local btnPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                    Parent = dropdown.Button,
                })
                
                local btnLayout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Parent = dropdown.Button,
                })
                
                dropdown.SelectedLabel = New("TextLabel", {
                    Text = dropdown.Default or "Select...",
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.SecondaryText,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -20, 1, 0),
                    Parent = dropdown.Button,
                })
                
                local arrow = New("ImageLabel", {
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundTransparency = 1,
                    Image = GetIcon("chevrons-up-down"),
                    ImageColor3 = self.Theme.SecondaryText,
                    Parent = dropdown.Button,
                })
                
                dropdown.Menu = RoundFrame(10, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 1, 4),
                    ImageColor3 = self.Theme.Background,
                    ImageTransparency = 0.05,
                    Visible = false,
                    ZIndex = 10,
                    Parent = dropdown.Button,
                })
                
                local menuStroke = New("UIStroke", {
                    Color = self.Theme.Border,
                    Thickness = 1,
                    Parent = dropdown.Menu,
                })
                
                local menuPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 6),
                    PaddingRight = UDim.new(0, 6),
                    PaddingTop = UDim.new(0, 6),
                    PaddingBottom = UDim.new(0, 6),
                    Parent = dropdown.Menu,
                })
                
                local menuLayout = New("UIListLayout", {
                    Padding = UDim.new(0, 4),
                    Parent = dropdown.Menu,
                })
                
                for _, option in pairs(dropdown.Options) do
                    local optBtn = RoundFrame(6, "Squircle", {
                        Size = UDim2.new(1, 0, 0, 28),
                        ImageColor3 = self.Theme.ElementBackground,
                        ImageTransparency = 1,
                        Parent = dropdown.Menu,
                    })
                    
                    local optLabel = New("TextLabel", {
                        Text = option,
                        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                        TextSize = 13,
                        TextColor3 = self.Theme.Text,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        Parent = optBtn,
                    })
                    
                    local optHitbox = New("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Parent = optBtn,
                    })
                    
                    optHitbox.MouseEnter:Connect(function()
                        Tween(optBtn, 0.15, {ImageTransparency = 0.9})
                    end)
                    
                    optHitbox.MouseLeave:Connect(function()
                        Tween(optBtn, 0.15, {ImageTransparency = 1})
                    end)
                    
                    optHitbox.MouseButton1Click:Connect(function()
                        dropdown.SelectedLabel.Text = option
                        dropdown.SelectedLabel.TextColor3 = self.Theme.Text
                        dropdown:Close()
                        pcall(dropdown.Callback, option)
                    end)
                end
                
                function dropdown:Open()
                    dropdown.Opened = true
                    dropdown.Menu.Visible = true
                    Tween(arrow, 0.2, {Rotation = 180})
                    Tween(dropdown.Menu, 0.2, {Size = UDim2.new(1, 0, 0, math.min(#dropdown.Options * 32 + 12, 200))})
                end
                
                function dropdown:Close()
                    dropdown.Opened = false
                    Tween(arrow, 0.2, {Rotation = 0})
                    Tween(dropdown.Menu, 0.2, {Size = UDim2.new(1, 0, 0, 0)})
                    task.delay(0.2, function()
                        if not dropdown.Opened then
                            dropdown.Menu.Visible = false
                        end
                    end)
                end
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = dropdown.Button,
                })
                
                hitbox.MouseButton1Click:Connect(function()
                    if dropdown.Opened then
                        dropdown:Close()
                    else
                        dropdown:Open()
                    end
                end)
                
                return dropdown
            end
            
            function section:Input(config)
                local input = {}
                input.Title = config.Title or "Input"
                input.Default = config.Default or ""
                input.Placeholder = config.Placeholder or "Enter text..."
                input.Callback = config.Callback or function() end
                
                input.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 60),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 6),
                    Parent = input.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = input.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    Parent = input.Frame,
                })
                
                input.BoxFrame = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 36),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.9,
                    Parent = input.Frame,
                })
                
                local boxPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                    Parent = input.BoxFrame,
                })
                
                input.TextBox = New("TextBox", {
                    Text = input.Default,
                    PlaceholderText = input.Placeholder,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    PlaceholderColor3 = self.Theme.SecondaryText,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    ClearTextOnFocus = false,
                    Parent = input.BoxFrame,
                })
                
                input.TextBox.Focused:Connect(function()
                    Tween(input.BoxFrame, 0.2, {ImageTransparency = 0.8, ImageColor3 = self.Theme.Accent})
                end)
                
                input.TextBox.FocusLost:Connect(function(enterPressed)
                    Tween(input.BoxFrame, 0.2, {ImageTransparency = 0.9, ImageColor3 = self.Theme.ElementBackground})
                    pcall(input.Callback, input.TextBox.Text, enterPressed)
                end)
                
                return input
            end
            
            return section
        end
        
        table.insert(self.Tabs, tab)
        
        if #self.Tabs == 1 then
            task.delay(0.1, function()
                tab:Select()
            end)
        end
        
        return tab
    end
    
    self.ScreenGui.Parent = game:GetService("CoreGui")
    self.NotificationGui.Parent = game:GetService("CoreGui")
    
    Tween(self.Background, 0.4, {ImageTransparency = 0})
    Tween(self.GlassOverlay, 0.4, {ImageTransparency = 0.95})
    
    return self
end

return CcatUI