                })
                
                local percent = (slider.Value - slider.Min) / (slider.Max - slider.Min)
                slider.Fill = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(percent, 0, 1, 0),
                    ImageColor3 = self.Theme.SliderFill,
                    ImageTransparency = 0,
                    Parent = slider.Track,
