    function self:Open()
        if self.Destroyed then return end
        self.Closed = false
        
        if self.OpenButtonFrame then
            Tween(self.OpenButtonFrame, 0.2, {Position = UDim2.new(0, -150, 0, 24)})
            task.delay(0.2, function()
                self.OpenButtonFrame.Visible = false
            end)
        end
        
        self.MainFrame.Visible = true
        Tween(self.Background, 0.35, {ImageTransparency = 0})
        Tween(self.GlassOverlay, 0.35, {ImageTransparency = 0.97})
        Tween(self.Shadow, 0.35, {ImageTransparency = 0.5})
        Tween(self.MainFrame, 0.4, {Size = self.Size}, Enum.EasingStyle.Back)
        
        if self.OnOpen then pcall(self.OnOpen) end
    end
    
    function self:Close()
        self.Closed = true
        
        Tween(self.Background, 0.3, {ImageTransparency = 1})
        Tween(self.GlassOverlay, 0.3, {ImageTransparency = 1})
        Tween(self.Shadow, 0.3, {ImageTransparency = 1})
        Tween(self.MainFrame, 0.3, {Size = UDim2.new(0, self.Size.X.Offset * 0.9, 0, self.Size.Y.Offset * 0.9)})
        
        task.delay(0.3, function()
