                    BackgroundTransparency = 1,
                    Parent = minusBtn,
                })
                
                numInput.BoxFrame = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, -84, 0, 36),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.85,
                    Parent = inputContainer,
                })
                
                local boxPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                    Parent = numInput.BoxFrame,
                })
                
                numInput.TextBox = New("TextBox", {
                    Text = tostring(numInput.Value),
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 13,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    ClearTextOnFocus = false,
                    Parent = numInput.BoxFrame,
                })
                
                local plusBtn = RoundFrame(6, "Squircle", {
                    Size = UDim2.new(0, 36, 0, 36),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.85,
                    Parent = inputContainer,
                })
                
                local plusIcon = New("ImageLabel", {
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundTransparency = 1,
                    Image = GetIcon("plus"),
                    ImageColor3 = self.Theme.Text,
                    Parent = plusBtn,
                })
                
                local plusHitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = plusBtn,
                })
                
                function numInput:Set(value)
                    numInput.Value = math.clamp(value, numInput.Min, numInput.Max)
                    numInput.TextBox.Text = tostring(numInput.Value)
                    pcall(numInput.Callback, numInput.Value)
                end
                
                minusHitbox.MouseButton1Click:Connect(function()
                    numInput:Set(numInput.Value - numInput.Step)
                end)
                
                plusHitbox.MouseButton1Click:Connect(function()
                    numInput:Set(numInput.Value + numInput.Step)
                end)
                
                numInput.TextBox.FocusLost:Connect(function()
                    local num = tonumber(numInput.TextBox.Text)
                    if num then
                        numInput:Set(num)
                    else
                        numInput.TextBox.Text = tostring(numInput.Value)
                    end
                end)
                
                return numInput
            end
            
            return section
        end
        
        table.insert(self.Tabs, tab)
        
        if #self.Tabs == 1 then
            task.delay(0.2, function()
                tab:Select()
            end)
        end
        
        return tab
    end
    
    self.ScreenGui.Parent = CoreGui
    self.NotificationGui.Parent = CoreGui
    self.WatermarkGui.Parent = CoreGui
    
    return self
end

