    function self:Open()
        if self.Destroyed then return end
        self.Closed = false
        
        if self.OpenButtonFrame then
            self.OpenButtonFrame.Visible = false
        end
        
        self.MainFrame.Visible = true
        Tween(self.Background, 0.3, {ImageTransparency = 0})
        Tween(self.GlassOverlay, 0.3, {ImageTransparency = 0.95})
        Tween(self.Shadow, 0.3, {ImageTransparency = 0.6})
        
        if self.OnOpen then
            pcall(self.OnOpen)
        end
    end
    
    function self:Close()
        self.Closed = true
        
        Tween(self.Background, 0.3, {ImageTransparency = 1})
        Tween(self.GlassOverlay, 0.3, {ImageTransparency = 1})
        Tween(self.Shadow, 0.3, {ImageTransparency = 1})
        
        task.delay(0.3, function()
            if self.Closed and not self.Destroyed then
                self.MainFrame.Visible = false
                if self.OpenButtonFrame then
                    self.OpenButtonFrame.Visible = true
                end
            end
        end)
        
        if self.OnClose then
            pcall(self.OnClose)
        end
    end
    
    function self:Destroy()
        self.Destroyed = true
        self.ScreenGui:Destroy()
        self.NotificationGui:Destroy()
    end
    
