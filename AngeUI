            function section:MultiDropdown(config)
                local dropdown = {}
                dropdown.Title = config.Title or "Multi Dropdown"
                dropdown.Options = config.Options or {}
                dropdown.Default = config.Default or {}
                dropdown.Callback = config.Callback or function() end
                dropdown.Opened = false
                dropdown.Selected = {}
                
                for _, v in pairs(dropdown.Default) do
                    dropdown.Selected[v] = true
                end
                
                dropdown.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 6),
                    Parent = dropdown.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = dropdown.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 13,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 16),
                    Parent = dropdown.Frame,
                })
                
                dropdown.Button = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 34),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.85,
                    Parent = dropdown.Frame,
                })
                
                local btnPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                    Parent = dropdown.Button,
                })
                
                local btnLayout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Parent = dropdown.Button,
                })
                
                dropdown.SelectedLabel = New("TextLabel", {
                    Text = #dropdown.Default > 0 and table.concat(dropdown.Default, ", ") or "Select...",
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 13,
                    TextColor3 = #dropdown.Default > 0 and self.Theme.Text or self.Theme.SecondaryText,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -22, 1, 0),
                    Parent = dropdown.Button,
                })
                
                local arrow = New("ImageLabel", {
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundTransparency = 1,
                    Image = GetIcon("chevrons-up-down"),
                    ImageColor3 = self.Theme.SecondaryText,
                    Parent = dropdown.Button,
                })
                
                dropdown.Menu = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 1, 4),
                    ImageColor3 = self.Theme.Background,
                    ImageTransparency = 1,
                    Visible = false,
                    ZIndex = 10,
                    Parent = dropdown.Button,
                })
                
                local menuStroke = New("UIStroke", {
                    Color = self.Theme.Border,
                    Thickness = 1,
                    Parent = dropdown.Menu,
                })
                
                local menuPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 6),
                    PaddingRight = UDim.new(0, 6),
                    PaddingTop = UDim.new(0, 6),
                    PaddingBottom = UDim.new(0, 6),
                    Parent = dropdown.Menu,
                })
                
                local menuLayout = New("UIListLayout", {
                    Padding = UDim.new(0, 4),
                    Parent = dropdown.Menu,
                })
                
                local optionButtons = {}
                
                for _, option in pairs(dropdown.Options) do
                    local optBtn = RoundFrame(6, "Squircle", {
                        Size = UDim2.new(1, 0, 0, 28),
                        ImageColor3 = self.Theme.ElementBackground,
                        ImageTransparency = 1,
                        Parent = dropdown.Menu,
                    })
                    
                    local optLayout = New("UIListLayout", {
                        FillDirection = Enum.FillDirection.Horizontal,
                        Padding = UDim.new(0, 6),
                        VerticalAlignment = Enum.VerticalAlignment.Center,
                        Parent = optBtn,
                    })
                    
                    local optPadding = New("UIPadding", {
                        PaddingLeft = UDim.new(0, 8),
                        Parent = optBtn,
                    })
                    
                    local checkBox = RoundFrame(4, "Squircle", {
                        Size = UDim2.new(0, 16, 0, 16),
                        ImageColor3 = dropdown.Selected[option] and self.Theme.ToggleEnabled or self.Theme.ToggleDisabled,
                        ImageTransparency = 0,
                        Parent = optBtn,
                    })
                    
                    local checkIcon = New("ImageLabel", {
                        Size = UDim2.new(0, 10, 0, 10),
                        Position = UDim2.new(0.5, 0, 0.5, 0),
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        BackgroundTransparency = 1,
                        Image = GetIcon("check"),
                        ImageColor3 = Color3.new(1, 1, 1),
                        ImageTransparency = dropdown.Selected[option] and 0 or 1,
                        Parent = checkBox,
                    })
                    
                    local optLabel = New("TextLabel", {
                        Text = option,
                        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                        TextSize = 12,
                        TextColor3 = self.Theme.Text,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, -24, 1, 0),
                        Parent = optBtn,
                    })
                    
                    local optHitbox = New("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Parent = optBtn,
                    })
                    
                    optHitbox.MouseEnter:Connect(function()
                        Tween(optBtn, 0.15, {ImageTransparency = 0.85})
                    end)
                    
                    optHitbox.MouseLeave:Connect(function()
                        Tween(optBtn, 0.15, {ImageTransparency = 1})
                    end)
                    
                    optHitbox.MouseButton1Click:Connect(function()
                        dropdown.Selected[option] = not dropdown.Selected[option]
                        Tween(checkBox, 0.15, {ImageColor3 = dropdown.Selected[option] and self.Theme.ToggleEnabled or self.Theme.ToggleDisabled})
                        Tween(checkIcon, 0.15, {ImageTransparency = dropdown.Selected[option] and 0 or 1})
                        
                        local selectedList = {}
                        for opt, selected in pairs(dropdown.Selected) do
                            if selected then
                                table.insert(selectedList, opt)
                            end
                        end
                        
                        dropdown.SelectedLabel.Text = #selectedList > 0 and table.concat(selectedList, ", ") or "Select..."
                        dropdown.SelectedLabel.TextColor3 = #selectedList > 0 and self.Theme.Text or self.Theme.SecondaryText
                        
                        pcall(dropdown.Callback, selectedList)
                    end)
                    
                    optionButtons[option] = {Btn = optBtn, Check = checkBox, Icon = checkIcon}
                end
                
                function dropdown:Open()
                    dropdown.Opened = true
                    dropdown.Menu.Visible = true
                    Tween(arrow, 0.2, {Rotation = 180})
                    Tween(dropdown.Menu, 0.2, {ImageTransparency = 0.05, Size = UDim2.new(1, 0, 0, math.min(#dropdown.Options * 32 + 12, 180))})
                end
                
                function dropdown:Close()
                    dropdown.Opened = false
                    Tween(arrow, 0.2, {Rotation = 0})
                    Tween(dropdown.Menu, 0.15, {ImageTransparency = 1, Size = UDim2.new(1, 0, 0, 0)})
                    task.delay(0.15, function()
                        if not dropdown.Opened then
                            dropdown.Menu.Visible = false
                        end
                    end)
                end
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = dropdown.Button,
                })
                
                hitbox.MouseEnter:Connect(function()
                    Tween(dropdown.Button, 0.15, {ImageTransparency = 0.75})
                end)
                
                hitbox.MouseLeave:Connect(function()
                    Tween(dropdown.Button, 0.15, {ImageTransparency = 0.85})
                end)
                
                hitbox.MouseButton1Click:Connect(function()
                    if dropdown.Opened then
                        dropdown:Close()
                    else
                        dropdown:Open()
                    end
                end)
                
                return dropdown
            end
            
            function section:List(config)
                local list = {}
                list.Title = config.Title or "List"
                list.Options = config.Options or {}
                list.Default = config.Default
                list.Callback = config.Callback or function() end
                
                list.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 6),
                    Parent = list.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = list.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 13,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 16),
                    Parent = list.Frame,
                })
                
                list.Container = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(1, 0, 0, math.min(#list.Options * 30 + 12, 180)),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.9,
                    Parent = list.Frame,
                })
                
                local containerPadding = New("UIPadding", {
                    PaddingLeft = UDim.new(0, 6),
                    PaddingRight = UDim.new(0, 6),
                    PaddingTop = UDim.new(0, 6),
                    PaddingBottom = UDim.new(0, 6),
                    Parent = list.Container,
                })
                
                local scrollFrame = New("ScrollingFrame", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = self.Theme.Accent,
                    ScrollingDirection = Enum.ScrollingDirection.Y,
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    Parent = list.Container,
                })
                
                local scrollLayout = New("UIListLayout", {
                    Padding = UDim.new(0, 2),
                    Parent = scrollFrame,
                })
                
                list.Selected = list.Default
                local optionFrames = {}
                
                for _, option in pairs(list.Options) do
                    local optBtn = RoundFrame(6, "Squircle", {
                        Size = UDim2.new(1, 0, 0, 26),
                        ImageColor3 = option == list.Default and self.Theme.Accent or self.Theme.ElementBackground,
                        ImageTransparency = option == list.Default and 0 or 1,
                        Parent = scrollFrame,
                    })
                    
                    local optLabel = New("TextLabel", {
                        Text = option,
                        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                        TextSize = 12,
                        TextColor3 = option == list.Default and Color3.new(1, 1, 1) or self.Theme.Text,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        Parent = optBtn,
                    })
                    
                    local optHitbox = New("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Parent = optBtn,
                    })
                    
                    optHitbox.MouseEnter:Connect(function()
                        if list.Selected ~= option then
                            Tween(optBtn, 0.15, {ImageTransparency = 0.85})
                        end
                    end)
                    
                    optHitbox.MouseLeave:Connect(function()
                        if list.Selected ~= option then
                            Tween(optBtn, 0.15, {ImageTransparency = 1})
                        end
                    end)
                    
                    optHitbox.MouseButton1Click:Connect(function()
                        if list.Selected then
                            local prev = optionFrames[list.Selected]
                            if prev then
                                Tween(prev.Btn, 0.15, {ImageTransparency = 1, ImageColor3 = self.Theme.ElementBackground})
                                prev.Label.TextColor3 = self.Theme.Text
                            end
                        end
                        
                        list.Selected = option
                        Tween(optBtn, 0.15, {ImageTransparency = 0, ImageColor3 = self.Theme.Accent})
                        optLabel.TextColor3 = Color3.new(1, 1, 1)
                        
                        pcall(list.Callback, option)
                    end)
                    
                    optionFrames[option] = {Btn = optBtn, Label = optLabel}
                end
                
                return list
            end
            
            function section:NumberInput(config)
                local numInput = {}
