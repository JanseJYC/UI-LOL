    function self:Open()
        if self.Destroyed then return end
        self.Closed = false
        
        if self.OpenButtonFrame then
            Tween(self.OpenButtonFrame, 0.2, {Position = UDim2.new(0, -130, 0, 20)})
            task.delay(0.2, function()
                self.OpenButtonFrame.Visible = false
            end)
        end
        
        self.MainFrame.Visible = true
        Tween(self.Background, 0.3, {ImageTransparency = 0})
        Tween(self.MainFrame, 0.3, {Size = self.Size}, Enum.EasingStyle.Back)
        
        if self.OnOpen then pcall(self.OnOpen) end
    end
    
    function self:Close()
        self.Closed = true
        
        Tween(self.Background, 0.25, {ImageTransparency = 1})
        Tween(self.MainFrame, 0.25, {Size = UDim2.new(0, self.Size.X.Offset * 0.9, 0, self.Size.Y.Offset * 0.9)})
        
        task.delay(0.25, function()
            if self.Closed and not self.Destroyed then
                self.MainFrame.Visible = false
                if self.OpenButtonFrame then
                    self.OpenButtonFrame.Visible = true
                    self.OpenButtonFrame.Position = UDim2.new(0, -130, 0, 20)
                    Tween(self.OpenButtonFrame, 0.3, {Position = UDim2.new(0, 20, 0, 20)})
                end
            end
        end)
        
        if self.OnClose then pcall(self.OnClose) end
    end
    
    function self:Destroy()
        self.Destroyed = true
        Tween(self.MainFrame, 0.2, {Size = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        Tween(self.WatermarkFrame, 0.2, {Position = UDim2.new(0, -250, 0.02, 0)})
        task.wait(0.2)
        self.ScreenGui:Destroy()
        self.NotificationGui:Destroy()
        self.WatermarkGui:Destroy()
    end
    
