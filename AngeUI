                    Padding = UDim.new(0, 12),
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Parent = keybind.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = keybind.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -70, 1, 0),
                    Parent = keybind.Frame,
                })
                
                keybind.Button = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(0, 70, 0, 32),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.85,
                    Parent = keybind.Frame,
                })
                
                local keyLabel = New("TextLabel", {
                    Text = keybind.Default.Name ~= "Unknown" and keybind.Default.Name or "None",
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 12,
                    TextColor3 = self.Theme.SecondaryText,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Parent = keybind.Button,
                })
                
                local listening = false
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = keybind.Frame,
                })
                
                hitbox.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    keyLabel.Text = "..."
                    Tween(keybind.Button, 0.2, {ImageTransparency = 0.6, ImageColor3 = self.Theme.Accent})
                    keyLabel.TextColor3 = self.Theme.Text
                    
                    local connection
                    connection = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            keybind.Value = input.KeyCode
                            keyLabel.Text = input.KeyCode.Name
                            keyLabel.TextColor3 = self.Theme.SecondaryText
                            Tween(keybind.Button, 0.2, {ImageTransparency = 0.85, ImageColor3 = self.Theme.ElementBackground})
                            listening = false
                            connection:Disconnect()
                            pcall(keybind.Callback, input.KeyCode)
                        end
                    end)
                end)
                
                hitbox.MouseEnter:Connect(function()
                    if not listening then
                        Tween(keybind.Button, 0.2, {ImageTransparency = 0.75})
                    end
                end)
                
                hitbox.MouseLeave:Connect(function()
                    if not listening then
                        Tween(keybind.Button, 0.2, {ImageTransparency = 0.85})
                    end
                end)
                
                return keybind
            end
            
            function section:ColorPicker(config)
                local picker = {}
                picker.Title = config.Title or "Color Picker"
                picker.Default = config.Default or Color3.fromRGB(99, 102, 241)
                picker.Callback = config.Callback or function() end
                picker.Value = picker.Default
                
                picker.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 38),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    Padding = UDim.new(0, 12),
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Parent = picker.Frame,
                })
                
                local label = New("TextLabel", {
                    Text = picker.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -50, 1, 0),
                    Parent = picker.Frame,
                })
                
                picker.Display = RoundFrame(8, "Squircle", {
                    Size = UDim2.new(0, 44, 0, 28),
                    ImageColor3 = picker.Default,
                    ImageTransparency = 0,
                    Parent = picker.Frame,
                })
                
                local stroke = New("UIStroke", {
                    Color = self.Theme.Border,
                    Thickness = 1,
                    Parent = picker.Display,
                })
                
                local hitbox = New("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Parent = picker.Frame,
                })
                
                local pickerOpen = false
                local pickerFrame = nil
                
                hitbox.MouseButton1Click:Connect(function()
                    if pickerOpen then
                        if pickerFrame then
                            Tween(pickerFrame, 0.2, {Size = UDim2.new(1, 0, 0, 0)}, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                            task.delay(0.2, function()
                                if pickerFrame then pickerFrame:Destroy() pickerFrame = nil end
                            end)
                        end
                        pickerOpen = false
                        return
                    end
                    
                    pickerOpen = true
                    pickerFrame = New("Frame", {
                        Size = UDim2.new(1, 0, 0, 0),
                        Position = UDim2.new(0, 0, 1, 8),
                        BackgroundTransparency = 1,
                        ZIndex = 20,
                        Parent = picker.Frame,
                    })
                    
                    local pickerBg = RoundFrame(12, "Squircle", {
                        Size = UDim2.new(1, 0, 1, 0),
                        ImageColor3 = self.Theme.ElementBackground,
                        ImageTransparency = 0.9,
                        Parent = pickerFrame,
                    })
                    
                    local pickerPadding = New("UIPadding", {
                        PaddingLeft = UDim.new(0, 12),
                        PaddingRight = UDim.new(0, 12),
                        PaddingTop = UDim.new(0, 12),
                        PaddingBottom = UDim.new(0, 12),
                        Parent = pickerBg,
                    })
                    
                    local pickerLayout = New("UIListLayout", {
                        Padding = UDim.new(0, 10),
                        Parent = pickerBg,
                    })
                    
                    local hueSlider = New("Frame", {
                        Size = UDim2.new(1, 0, 0, 20),
                        BackgroundTransparency = 1,
                        Parent = pickerBg,
                    })
                    
                    local hueGradient = New("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                            ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
                            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
                            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                            ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
                            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
                        }),
                        Parent = hueSlider,
                    })
                    
                    local hueBg = RoundFrame(999, "Squircle", {
                        Size = UDim2.new(1, 0, 1, 0),
                        ImageColor3 = Color3.new(1, 1, 1),
                        ImageTransparency = 0,
                        Parent = hueSlider,
                    })
                    
                    hueGradient.Parent = hueBg
                    
                    local satValFrame = New("Frame", {
                        Size = UDim2.new(1, 0, 0, 80),
                        BackgroundColor3 = Color3.fromRGB(255, 0, 0),
                        BorderSizePixel = 0,
                        Parent = pickerBg,
                    })
                    
                    local satGradient = New("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
                        }),
                        Parent = satValFrame,
                    })
                    
                    local valFrame = New("Frame", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Parent = satValFrame,
                    })
                    
                    local valGradient = New("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0)),
                        }),
                        Transparency = NumberSequence.new({
                            NumberSequenceKeypoint.new(0, 1),
                            NumberSequenceKeypoint.new(1, 0),
                        }),
                        Rotation = 90,
                        Parent = valFrame,
                    })
                    
                    Tween(pickerFrame, 0.3, {Size = UDim2.new(1, 0, 0, 140)}, Enum.EasingStyle.Back)
                end)
                
                hitbox.MouseEnter:Connect(function()
                    Tween(picker.Display, 0.2, {Size = UDim2.new(0, 48, 0, 30)})
                end)
                
                hitbox.MouseLeave:Connect(function()
                    Tween(picker.Display, 0.2, {Size = UDim2.new(0, 44, 0, 28)})
                end)
                
                function picker:Set(color)
                    picker.Value = color
                    Tween(picker.Display, 0.2, {ImageColor3 = color})
                    pcall(picker.Callback, color)
                end
                
                return picker
            end
            
            function section:ProgressBar(config)
                local progress = {}
                progress.Title = config.Title or "Progress"
                progress.Value = config.Value or 0
                progress.Max = config.Max or 100
                
                progress.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 46),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local layout = New("UIListLayout", {
                    Padding = UDim.new(0, 8),
                    Parent = progress.Frame,
                })
                
                local header = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Parent = progress.Frame,
                })
                
                local headerLayout = New("UIListLayout", {
                    FillDirection = Enum.FillDirection.Horizontal,
                    Parent = header,
                })
                
                local title = New("TextLabel", {
                    Text = progress.Title,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.SemiBold),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -50, 1, 0),
                    Parent = header,
                })
                
                progress.ValueLabel = New("TextLabel", {
                    Text = math.floor((progress.Value / progress.Max) * 100) .. "%",
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold),
                    TextSize = 14,
                    TextColor3 = self.Theme.Accent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0, 50, 1, 0),
                    Parent = header,
                })
                
                progress.Track = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(1, 0, 0, 10),
                    ImageColor3 = self.Theme.ToggleDisabled,
                    ImageTransparency = 0.5,
                    Parent = progress.Frame,
                })
                
                progress.Fill = RoundFrame(999, "Squircle", {
                    Size = UDim2.new(progress.Value / progress.Max, 0, 1, 0),
                    ImageColor3 = self.Theme.Accent,
                    ImageTransparency = 0,
                    Parent = progress.Track,
                })
                
                function progress:Set(value)
                    progress.Value = math.clamp(value, 0, progress.Max)
                    local percent = progress.Value / progress.Max
                    progress.ValueLabel.Text = math.floor(percent * 100) .. "%"
                    Tween(progress.Fill, 0.3, {Size = UDim2.new(percent, 0, 1, 0)})
                end
                
                return progress
            end
            
            function section:Image(config)
                local img = {}
                img.Image = config.Image or ""
                img.Size = config.Size or UDim2.new(1, 0, 0, 150)
                
                img.Frame = RoundFrame(12, "Squircle", {
                    Size = img.Size,
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.9,
                    Parent = section.Frame,
                })
                
                local imageLabel = New("ImageLabel", {
                    Size = UDim2.new(1, -8, 1, -8),
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundTransparency = 1,
                    Image = img.Image,
                    ScaleType = Enum.ScaleType.Fit,
                    Parent = img.Frame,
                })
                
                return img
            end
            
            function section:Search(config)
                local search = {}
                search.Placeholder = config.Placeholder or "Search..."
                search.Callback = config.Callback or function() end
                
                search.Frame = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 42),
                    BackgroundTransparency = 1,
                    Parent = section.Frame,
                })
                
                local searchBg = RoundFrame(10, "Squircle", {
                    Size = UDim2.new(1, 0, 1, 0),
                    ImageColor3 = self.Theme.ElementBackground,
                    ImageTransparency = 0.85,
                    Parent = search.Frame,
                })
                
                local icon = New("ImageLabel", {
                    Size = UDim2.new(0, 18, 0, 18),
                    Position = UDim2.new(0, 12, 0.5, 0),
                    AnchorPoint = Vector2.new(0, 0.5),
                    BackgroundTransparency = 1,
                    Image = GetIcon("search"),
                    ImageColor3 = self.Theme.SecondaryText,
                    Parent = searchBg,
                })
                
                search.TextBox = New("TextBox", {
                    Text = "",
                    PlaceholderText = search.Placeholder,
                    FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
                    TextSize = 14,
                    TextColor3 = self.Theme.Text,
                    PlaceholderColor3 = self.Theme.SecondaryText,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 38, 0, 0),
                    Size = UDim2.new(1, -50, 1, 0),
                    Parent = searchBg,
                })
                
                search.TextBox.Focused:Connect(function()
                    Tween(searchBg, 0.2, {ImageTransparency = 0.7, ImageColor3 = self.Theme.Hover})
                    Tween(icon, 0.2, {ImageColor3 = self.Theme.Accent})
                end)
                
                search.TextBox.FocusLost:Connect(function()
                    Tween(searchBg, 0.2, {ImageTransparency = 0.85, ImageColor3 = self.Theme.ElementBackground})
                    Tween(icon, 0.2, {ImageColor3 = self.Theme.SecondaryText})
                end)
                
                search.TextBox:GetPropertyChangedSignal("Text"):Connect(function()
                    pcall(search.Callback, search.TextBox.Text)
                end)
                
                return search
            end
            
            return section
        end
        
        table.insert(self.Tabs, tab)
        
        if #self.Tabs == 1 then
            task.delay(0.2, function()
                tab:Select()
            end)
        end
        
        return tab
    end
    
    self.ScreenGui.Parent = CoreGui
    self.NotificationGui.Parent = CoreGui
    self.WatermarkGui.Parent = CoreGui
    
    return self
end

return CcatUI