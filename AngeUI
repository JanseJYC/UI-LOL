local function New(instanceType, properties, children)
    local instance = Instance.new(instanceType)
    for property, value in pairs(properties or {}) do
        instance[property] = value
    end
    for _, child in pairs(children or {}) do
        child.Parent = instance
    end
    return instance
end

local function Tween(instance, duration, properties, easingStyle, easingDirection)
    if not instance then return nil end
    local tween = TweenService:Create(instance, TweenInfo.new(duration, easingStyle or Enum.EasingStyle.Quint, easingDirection or Enum.EasingDirection.Out), properties)
    tween:Play()
    return tween
end

local function RoundFrame(radius, shape, properties, children)
    local imageLabel = New("ImageLabel", {
        Name = shape or "Squircle",
        BackgroundTransparency = 1,
        Image = "rbxassetid://80999662900595",
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(99, 99, 99, 99),
        SliceScale = 1,
    })
    
    for prop, val in pairs(properties or {}) do
        imageLabel[prop] = val
    end
    
    for _, child in pairs(children or {}) do
        child.Parent = imageLabel
    end
    
    return imageLabel
end

local function Drag(frame, dragPoints, callback)
    local dragging = false
    local dragInput = nil
    local startPos = nil
    local startInputPos = nil
    
    local function update(input)
        local delta = input.Position - startInputPos
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    
    for _, point in pairs(dragPoints or {frame}) do
        point.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startInputPos = input.Position
                startPos = frame.Position
                
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
                
                if callback then callback(true) end
            end
        end)
        
        point.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
    end
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
    
    return {
        Set = function(enabled) dragging = enabled end
    }
end

