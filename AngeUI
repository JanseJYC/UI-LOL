    local function CreateWindowButton(iconName, color, callback)
        local btnContainer = New("Frame", {
            Size = UDim2.new(0, 24, 0, 24),
            BackgroundTransparency = 1,
        })
        
        local btn = RoundFrame(999, "Squircle", {
            Size = UDim2.new(0, 10, 0, 10),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            ImageColor3 = color,
            ImageTransparency = 0,
            Parent = btnContainer,
        })
        
        local hitbox = New("TextButton", {
            Size = UDim2.new(1, 4, 1, 4),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundTransparency = 1,
            Parent = btn,
        })
        
        hitbox.MouseEnter:Connect(function()
            Tween(btn, 0.15, {ImageTransparency = 0.3, Size = UDim2.new(0, 12, 0, 12)})
        end)
        
        hitbox.MouseLeave:Connect(function()
            Tween(btn, 0.15, {ImageTransparency = 0, Size = UDim2.new(0, 10, 0, 10)})
        end)
        
        hitbox.MouseButton1Click:Connect(function()
            Tween(btn, 0.1, {Size = UDim2.new(0, 8, 0, 8)})
            task.delay(0.1, function()
                Tween(btn, 0.1, {Size = UDim2.new(0, 10, 0, 10)})
            end)
            if callback then callback() end
        end)
        
        return btnContainer
    end
    
    self.MinimizeBtn = CreateWindowButton("minus", self.Theme.Warning, function()
        self:Close()
    end)
    self.MinimizeBtn.Parent = self.WindowButtons
    
    self.CloseBtn = CreateWindowButton("x", self.Theme.Error, function()
        self:Destroy()
